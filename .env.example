# Copy to .env (or export these) before running the bot.
# Without ANTHROPIC_API_KEY the bot still works using the deterministic
# template composer — but Claude composition scores higher.

ANTHROPIC_API_KEY=
COMPOSER_MODEL=claude-sonnet-4-6
LLM_TIMEOUT_SECONDS=12

TEAM_NAME=Team Vera
TEAM_MEMBERS=Chelsi
CONTACT_EMAIL=chelsisinghal1362@gmail.com

# How long /v1/tick may spend composing before returning what it has.
TICK_BUDGET_SECONDS=20
